# ===== Base de datos (MySQL) =====
DATABASE_URL="mysql://root:@localhost:3306/mitiendita_db"

# ===== Aplicación =====
NODE_ENV=development
PORT=8300
PUBLIC_API_URL=http://localhost:8300/api
APP_NAME=MiTiendita
ROOT_DOMAIN=mitiendita.localhost

# ===== Autenticación (JWT) =====
JWT_ACCESS_SECRET=pon_aqui_un_secreto_fuerte
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=pon_aqui_otro_secreto_fuerte
JWT_REFRESH_TTL=2592000

# ===== Superadmin inicial (seed) =====
SUPERADMIN_EMAIL=admin@mitiendita.localhost
SUPERADMIN_PASSWORD=Admin12345

# ===== Cloudinary (Fase 2) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== WhatsApp Cloud API (notificaciones centrales) =====
# Una sola cuenta/remitente de MiTiendita notifica a los dueños de las tiendas.
WHATSAPP_CLOUD_ENABLED=false
WHATSAPP_CLOUD_API_VERSION=v25.0
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_ACCESS_TOKEN=

# ── WhatsApp Cloud API (Meta) — opcional, para enviar la foto del comprobante automáticamente ──
WHATSAPP_CLOUD_ENABLED=false
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v21.0
