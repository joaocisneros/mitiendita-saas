// ╔══════════════════════════════════════════════════════════════╗
// ║  MiTiendita — Esquema de base de datos                         ║
// ║  Fase 0: Cimientos (núcleo multi-tenant + autenticación)      ║
// ╚══════════════════════════════════════════════════════════════╝

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

// ───────────────────────── ENUMS ─────────────────────────

enum CompanyStatus {
  active
  suspended
  inactive
}

enum MembershipRole {
  OWNER
  EMPLOYEE
}

enum OrderStatus {
  pending
  confirmed
  preparing
  out_for_delivery
  delivered
  cancelled
  expired
}

enum PaymentStatus {
  pending
  proof_submitted
  approved
  rejected
}

enum DeliveryMethod {
  pickup
  delivery
}

enum PaymentMethod {
  yape
}

enum SubscriptionStatus {
  trial // periodo de prueba
  active // pagado / al día
  past_due // pago pendiente / vencido
  cancelled // cancelado
}

enum AppointmentStatus {
  pending // solicitada, sin confirmar
  confirmed // confirmada por el negocio
  completed // atendida
  cancelled // cancelada
}

enum SubStatus {
  pending // solicitada, sin activar
  active // activa (con fecha de vencimiento)
  cancelled // cancelada / dada de baja
}

// ════════════════ ENTIDADES GLOBALES (sin company_id) ════════════════

/// Planes comerciales (Básico, Pro, Premium). Asignados manualmente en el MVP.
model Plan {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  priceMonth  Decimal  @default(0) @db.Decimal(10, 2) @map("price_month")
  maxProducts Int?     @map("max_products") // null = ilimitado
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  companies Company[]

  @@map("plans")
}

/// La empresa (negocio). Cada empresa = una tienda en el MVP.
model Company {
  id        String        @id @default(uuid())
  name      String // nombre comercial
  subdomain String        @unique
  status    CompanyStatus @default(active)
  planId    Int?          @map("plan_id")

  // Suscripción comercial (gestionada por el superadmin).
  subscriptionStatus   SubscriptionStatus @default(trial) @map("subscription_status")
  currentPeriodEndsAt  DateTime?          @map("current_period_ends_at")
  subscriptionNotes    String?            @map("subscription_notes") @db.Text

  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  plan        Plan?            @relation(fields: [planId], references: [id])
  settings    CompanySettings?
  memberships Membership[]
  categories  Category[]
  products    Product[]
  customers   Customer[]
  orders      Order[]
  payments    Payment[]
  stockMovements StockMovement[]
  appointments Appointment[]
  subscriptions Subscription[]

  @@index([status])
  @@map("companies")
}

/// Administradores de la plataforma (tabla separada por seguridad).
model SuperAdmin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  audits SuperAdminAudit[]

  @@map("super_admins")
}

/// Registro de acciones sensibles realizadas desde el panel global.
model SuperAdminAudit {
  id           String   @id @default(uuid())
  superAdminId String   @map("super_admin_id")
  action       String
  companyId    String?  @map("company_id")
  details      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  superAdmin SuperAdmin @relation(fields: [superAdminId], references: [id])

  @@index([superAdminId, createdAt])
  @@index([companyId, createdAt])
  @@map("super_admin_audits")
}

/// Subdominios reservados que ninguna empresa puede usar (www, api, admin...).
model ReservedSubdomain {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reserved_subdomains")
}

// ════════════════ IDENTIDAD Y ACCESO ════════════════

/// Usuario del panel (identidad global). Se vincula a empresas vía Membership.
model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships   Membership[]
  refreshTokens RefreshToken[]

  @@map("users")
}

/// Vincula un usuario con una empresa y su rol. Permite empleados a futuro.
model Membership {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  companyId String         @map("company_id")
  role      MembershipRole @default(OWNER)
  createdAt DateTime       @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("memberships")
}

/// Refresh tokens revocables (se guarda solo el hash, nunca el token en claro).
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

// ════════════════ CONFIGURACIÓN DE TIENDA (por empresa) ════════════════

/// Configuración de marca, pago Yape y entrega de cada tienda.
model CompanySettings {
  id              String   @id @default(uuid())
  companyId       String   @unique @map("company_id")
  storeName       String   @map("store_name")
  businessType    String?  @map("business_type") // informativo: Bodega, Farmacia, Ropa... (no bloquea nada)
  description     String?  @db.Text
  logoUrl         String?  @map("logo_url")
  primaryColor    String   @default("#2563eb") @map("primary_color")
  secondaryColor  String   @default("#f59e0b") @map("secondary_color")
  whatsappNumber  String?  @map("whatsapp_number")
  yapeQrUrl       String?  @map("yape_qr_url")
  yapeHolderName  String?  @map("yape_holder_name")
  yapeNumber      String?  @map("yape_number")
  currency        String   @default("PEN")
  timezone        String   @default("America/Lima")
  whatsappMessage String?  @map("whatsapp_message") @db.Text

  // Entrega
  allowsPickup   Boolean  @default(true) @map("allows_pickup")
  allowsDelivery Boolean  @default(true) @map("allows_delivery")
  deliveryFee    Decimal  @default(0) @db.Decimal(10, 2) @map("delivery_fee")
  minOrder       Decimal? @db.Decimal(10, 2) @map("min_order")
  storeAddress   String?  @map("store_address")
  deliveryNotes  String?  @map("delivery_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("company_settings")
}

// ════════════════ CATÁLOGO (por empresa) ════════════════

/// Categoría de productos. Sin jerarquías en el MVP.
model Category {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  name        String
  slug        String
  description String?   @db.Text
  imageUrl    String?   @map("image_url")
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  company  Company   @relation(fields: [companyId], references: [id])
  products Product[]

  // slug único por empresa. Al eliminar (lógico) se libera renombrando el slug.
  @@unique([companyId, slug])
  @@index([companyId])
  @@map("categories")
}

/// Producto físico. Una imagen principal, sin variantes en el MVP.
model Product {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  categoryId  String?   @map("category_id")
  name        String
  slug        String
  description String?   @db.Text
  price       Decimal   @db.Decimal(12, 2) // dinero exacto, nunca float
  stock       Int       @default(0) // unidades físicas totales
  reserved    Int       @default(0) // unidades comprometidas por pedidos pendientes
  sku         String?
  imageUrl    String?   @map("image_url")
  isFeatured  Boolean   @default(false) @map("is_featured")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  company    Company     @relation(fields: [companyId], references: [id])
  category   Category?   @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  stockMovements StockMovement[]
  appointments Appointment[]
  subscriptions Subscription[]

  // slug y SKU únicos por empresa. SKU es opcional (varios NULL permitidos).
  @@unique([companyId, slug])
  @@unique([companyId, sku])
  @@index([companyId])
  @@index([companyId, categoryId])
  @@map("products")
}

// ════════════════ CLIENTES Y PEDIDOS (por empresa) ════════════════

/// Cliente comprador. Identificado por teléfono dentro de cada empresa.
model Customer {
  id              String    @id @default(uuid())
  companyId       String    @map("company_id")
  name            String
  phone           String // teléfono normalizado
  address         String?   @db.Text
  firstPurchaseAt DateTime? @map("first_purchase_at")
  lastPurchaseAt  DateTime? @map("last_purchase_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  orders  Order[]

  @@unique([companyId, phone])
  @@index([companyId])
  @@map("customers")
}

/// Pedido. Guarda copias históricas de los datos del cliente.
model Order {
  id             String         @id @default(uuid())
  companyId      String         @map("company_id")
  customerId     String         @map("customer_id")
  publicCode     String         @unique @map("public_code")
  status         OrderStatus    @default(pending)
  paymentStatus  PaymentStatus  @default(pending) @map("payment_status")
  deliveryMethod DeliveryMethod @map("delivery_method")

  // Copia histórica de los datos al momento de la compra.
  customerName  String  @map("customer_name")
  customerPhone String  @map("customer_phone")
  address       String? @db.Text
  reference     String?
  customerNote  String? @map("customer_note") @db.Text

  subtotal    Decimal @db.Decimal(12, 2)
  deliveryFee Decimal @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)
  currency    String  @default("PEN")

  idempotencyKey       String?   @map("idempotency_key")
  reservationExpiresAt DateTime? @map("reservation_expires_at")
  confirmedAt          DateTime? @map("confirmed_at")
  deliveredAt          DateTime? @map("delivered_at")
  cancelledAt          DateTime? @map("cancelled_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  company  Company              @relation(fields: [companyId], references: [id])
  customer Customer             @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  history  OrderStatusHistory[]
  payment  Payment?

  // Idempotencia: una misma clave no crea dos pedidos en la misma empresa.
  @@unique([companyId, idempotencyKey])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@map("orders")
}

/// Línea de pedido con copia histórica (nombre, SKU, precio, cantidad).
model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String? @map("product_id")
  name      String
  sku       String?
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)
  quantity  Int
  lineTotal Decimal @map("line_total") @db.Decimal(12, 2)

  order   Order    @relation(fields: [orderId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

/// Historial de cambios de estado del pedido (auditoría).
model OrderStatusHistory {
  id              String   @id @default(uuid())
  orderId         String   @map("order_id")
  fromStatus      String?  @map("from_status")
  toStatus        String   @map("to_status")
  changedByUserId String?  @map("changed_by_user_id")
  comment         String?
  createdAt       DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_status_history")
}

/// Pago del pedido (Yape manual en el MVP).
model Payment {
  id                String        @id @default(uuid())
  companyId         String        @map("company_id")
  orderId           String        @unique @map("order_id")
  method            PaymentMethod @default(yape)
  expectedAmount    Decimal       @map("expected_amount") @db.Decimal(12, 2)
  reportedAmount    Decimal?      @map("reported_amount") @db.Decimal(12, 2)
  proofUrl          String?       @map("proof_url")
  status            PaymentStatus @default(pending)
  submittedAt       DateTime?     @map("submitted_at")
  validatedAt       DateTime?     @map("validated_at")
  validatedByUserId String?       @map("validated_by_user_id")
  rejectionComment  String?       @map("rejection_comment")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  @@index([companyId, status])
  @@map("payments")
}

enum StockMovementType {
  entry // entrada / reposición
  sale // salida por venta
  adjustment // ajuste manual
  return // devolución
  cancellation // cancelación de pedido
}

/// Historial de movimientos de stock (inventario).
model StockMovement {
  id              String            @id @default(uuid())
  companyId       String            @map("company_id")
  productId       String            @map("product_id")
  type            StockMovementType
  quantity        Int // delta aplicado al stock (positivo o negativo)
  reason          String?
  createdByUserId String?           @map("created_by_user_id")
  createdAt       DateTime          @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@map("stock_movements")
}

/// Cita/reserva de un servicio (rubros de Servicios: belleza, salud, etc.).
/// No mueve stock ni pagos; el negocio confirma y coordina la atención.
model Appointment {
  id            String            @id @default(uuid())
  companyId     String            @map("company_id")
  productId     String?           @map("product_id") // servicio relacionado (opcional)
  serviceName   String            @map("service_name") // copia histórica del nombre
  customerName  String            @map("customer_name")
  customerPhone String            @map("customer_phone")
  preferredAt   DateTime          @map("preferred_at") // día/hora deseado por el cliente
  note          String?           @db.Text
  status        AppointmentStatus @default(pending)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  company Company  @relation(fields: [companyId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([companyId, status])
  @@index([companyId, preferredAt])
  @@map("appointments")
}

/// Suscripción de un cliente a un plan digital (streaming, membresías, cursos).
/// Tiene período: el dueño la activa y controla su vencimiento para renovar.
model Subscription {
  id            String    @id @default(uuid())
  companyId     String    @map("company_id")
  productId     String?   @map("product_id") // plan relacionado (opcional)
  planName      String    @map("plan_name") // copia histórica del nombre del plan
  customerName  String    @map("customer_name")
  customerPhone String    @map("customer_phone")
  status        SubStatus @default(pending)
  startsAt      DateTime? @map("starts_at") // cuándo se activó
  endsAt        DateTime? @map("ends_at") // vencimiento (para avisar/renovar)
  note          String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  company Company  @relation(fields: [companyId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([companyId, status])
  @@index([companyId, endsAt])
  @@map("subscriptions")
}

/// Configuración global de la plataforma (fila única, id = 1).
model PlatformSettings {
  id              Int      @id @default(1)
  platformName    String   @default("MiTiendita") @map("platform_name")
  logoUrl         String?  @map("logo_url")
  mainDomain      String   @default("mitiendita.com") @map("main_domain")
  currency        String   @default("PEN")
  supportWhatsapp String?  @map("support_whatsapp")
  supportEmail    String?  @map("support_email")
  terms           String?  @db.Text
  privacy         String?  @db.Text
  trialDays       Int      @default(14) @map("trial_days")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}
